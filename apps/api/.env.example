# ======================================
# Portal Global Bravo — API (.env)
# Copie este arquivo para .env e preencha
# ======================================

# --- Oracle Database (obrigatórias) ---
ORACLE_HOST=
ORACLE_PORT=1521
ORACLE_SERVICE=
ORACLE_USER=
ORACLE_PASSWORD=

# --- Oracle (opcionais) ---
ORACLE_OWNER=
ORACLE_CURRENT_SCHEMA=

# --- Pool de conexões ---
DB_POOL_MIN=0
DB_POOL_MAX=4
DB_POOL_TIMEOUT_SEC=60

# --- Servidor ---
PORT=4001
HOST=0.0.0.0

# --- JWT ---
JWT_SECRET=

# --- CORS (separar domínios por vírgula) ---
ALLOWED_ORIGINS=http://localhost:3200

# --- Dashboard ---
DASHBOARD_SOURCE=pgb

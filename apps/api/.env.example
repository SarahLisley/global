# ======================================
# Portal Global Bravo — API (.env)
# Copie este arquivo para .env e preencha
# ======================================

# --- Oracle Database (obrigatórias) ---
ORACLE_HOST=
ORACLE_PORT=1521
ORACLE_SERVICE=
ORACLE_USER=
ORACLE_PASSWORD=

# --- Oracle (opcionais) ---
ORACLE_OWNER=
ORACLE_CURRENT_SCHEMA=

# --- Pool de conexões ---
DB_POOL_MIN=0
DB_POOL_MAX=4
DB_POOL_INCREMENT=1
DB_POOL_TIMEOUT_SEC=60
DB_POOL_QUEUE_TIMEOUT_MS=5000
DB_STMT_CACHE_SIZE=40
DB_FETCH_ARRAY_SIZE=100
DB_PREFETCH_ROWS=100
# DB_SLOW_QUERY_MS=500

# --- Servidor ---
PORT=4001
HOST=0.0.0.0
ENABLE_HTTPS=0

# --- JWT ---
JWT_SECRET=

# --- CORS (separar domínios por vírgula) ---
ALLOWED_ORIGINS=http://localhost:3200

# --- Dashboard ---
DASHBOARD_SOURCE=pgb
